    "@types/qrcode": "^1.5.6",
    "pixi.js": "^8.6.0",
    "qrcode": "^1.5.4",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@types/three": "^0.171.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
